---
// FormPartnership — G-will Chijioke (https://gwillchijioke.com)
const endpoint = import.meta.env.FORM_ENDPOINT || '';
const honeypot = import.meta.env.FORM_HONEYPOT_FIELD || 'website';
---

<form
  class="form-partnership"
  data-endpoint={endpoint}
  data-honeypot={honeypot}
  novalidate
>
  <div class="form-row">
    <div class="form-group">
      <label for="fp-name">Your Name <span aria-hidden="true">*</span></label>
      <input type="text" id="fp-name" name="name" required autocomplete="name" />
    </div>
    <div class="form-group">
      <label for="fp-email">Email <span aria-hidden="true">*</span></label>
      <input type="email" id="fp-email" name="email" required autocomplete="email" />
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="fp-org">Organisation / Brand <span aria-hidden="true">*</span></label>
      <input type="text" id="fp-org" name="organisation" required autocomplete="organization" />
    </div>
    <div class="form-group">
      <label for="fp-website">Website</label>
      <input type="url" id="fp-website" name="website_url" placeholder="https://" />
    </div>
  </div>

  <div class="form-group">
    <label for="fp-type">Partnership Type <span aria-hidden="true">*</span></label>
    <select id="fp-type" name="partnership_type" required>
      <option value="">Select a type</option>
      <option value="content">Content Collaboration</option>
      <option value="affiliate">Affiliate / Referral</option>
      <option value="sponsorship">Sponsorship</option>
      <option value="co-dev">Co-development</option>
      <option value="reseller">Reseller / White-label</option>
      <option value="other">Other</option>
    </select>
  </div>

  <div class="form-group">
    <label for="fp-audience">Your Audience / Reach</label>
    <select id="fp-audience" name="audience_size">
      <option value="">Prefer not to say</option>
      <option value="under-1k">Under 1,000</option>
      <option value="1k-10k">1,000 – 10,000</option>
      <option value="10k-100k">10,000 – 100,000</option>
      <option value="100k-plus">100,000+</option>
    </select>
  </div>

  <div class="form-group">
    <label for="fp-proposal">Partnership Proposal <span aria-hidden="true">*</span></label>
    <textarea id="fp-proposal" name="message" rows="6" required placeholder="Describe the partnership opportunity and what value it brings to both sides…"></textarea>
  </div>

  <!-- Honeypot -->
  <div class="form-honeypot" aria-hidden="true">
    <input type="text" name={honeypot} tabindex="-1" autocomplete="off" />
  </div>

  <div class="form-status" role="status" aria-live="polite"></div>

  <button type="submit" class="form-submit">
    <span class="btn-label">Submit Proposal</span>
    <span class="btn-loading" hidden>Sending…</span>
  </button>
</form>

<style>
  .form-partnership { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: .375rem; }
  .form-group label { font-size: .875rem; font-weight: 500; }
  .form-group label span { color: var(--color-accent, #e53e3e); }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%; padding: .625rem .75rem;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: .375rem; font-size: 1rem;
    background: var(--color-surface, #fff);
    color: var(--color-text, #111); transition: border-color .15s;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none; border-color: var(--color-accent, #3b82f6);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent, #3b82f6) 20%, transparent);
  }
  .form-honeypot { display: none; }
  .form-status { font-size: .875rem; min-height: 1.25rem; }
  .form-status.success { color: #16a34a; }
  .form-status.error   { color: #dc2626; }
  .form-submit {
    align-self: flex-start; padding: .625rem 1.5rem;
    background: var(--color-accent, #3b82f6);
    color: #fff; border: none; border-radius: .375rem;
    font-size: 1rem; font-weight: 500; cursor: pointer; transition: opacity .15s;
  }
  .form-submit:disabled { opacity: .6; cursor: not-allowed; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('.form-partnership');
  if (form) {
    const endpoint  = form.dataset.endpoint || '';
    const honeypot  = form.dataset.honeypot || 'website';
    const status    = form.querySelector<HTMLElement>('.form-status')!;
    const label     = form.querySelector<HTMLElement>('.btn-label')!;
    const loading   = form.querySelector<HTMLElement>('.btn-loading')!;
    const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!endpoint) { status.textContent = 'Form endpoint not configured.'; status.className = 'form-status error'; return; }
      const data = Object.fromEntries(new FormData(form));
      if (data[honeypot]) return;

      label.hidden = true; loading.hidden = false; submitBtn.disabled = true;
      status.textContent = ''; status.className = 'form-status';

      try {
        const nonceRes = await fetch(endpoint.replace('/forms/submit', '/nonce'));
        const { nonce } = await nonceRes.json();
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-WP-Nonce': nonce },
          body: JSON.stringify({ form_id: 'partnership', fields: data }),
        });
        const result = await res.json();
        status.textContent = result.message || (result.success ? 'Proposal submitted!' : 'Something went wrong.');
        status.className   = 'form-status ' + (result.success ? 'success' : 'error');
        if (result.success) form.reset();
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className   = 'form-status error';
      } finally {
        label.hidden = false; loading.hidden = true; submitBtn.disabled = false;
      }
    });
  }
</script>
