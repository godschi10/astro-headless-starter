---
/**
 * ShareBar.astro — G-will Chijioke (https://gwillchijioke.com)
 *
 * Client-side share buttons. URL and title are injected at build time.
 * Pass variant="compact" for the top-of-post strip, "full" for the bottom block.
 */
interface Props {
  url:      string;
  title:    string;
  variant?: 'compact' | 'full';
}

const {
  url,
  title,
  variant = 'compact',
} = Astro.props;

const encodedUrl   = encodeURIComponent( url );
const encodedTitle = encodeURIComponent( title );
---

<div class={`share-bar share-bar--${ variant }`} aria-label="Share this article">
  {variant === 'full' && (
    <p class="share-label">Share this article</p>
  )}
  <div class="share-buttons">
    <!-- X / Twitter -->
    <a
      href={`https://x.com/intent/post?url=${ encodedUrl }&text=${ encodedTitle }`}
      class="share-btn share-btn--x"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on X"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.258 5.626L18.244 2.25ZM17.08 18.75h1.833L6.988 4.126H5.024L17.08 18.75Z"/>
      </svg>
      {variant === 'full' && <span>X</span>}
    </a>

    <!-- Facebook -->
    <a
      href={`https://www.facebook.com/sharer/sharer.php?u=${ encodedUrl }`}
      class="share-btn share-btn--fb"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Facebook"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.885v2.254h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073Z"/>
      </svg>
      {variant === 'full' && <span>Facebook</span>}
    </a>

    <!-- WhatsApp -->
    <a
      href={`https://wa.me/?text=${ encodedTitle }%20${ encodedUrl }`}
      class="share-btn share-btn--wa"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on WhatsApp"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      {variant === 'full' && <span>WhatsApp</span>}
    </a>

    <!-- LinkedIn -->
    <a
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${ encodedUrl }`}
      class="share-btn share-btn--li"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on LinkedIn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      {variant === 'full' && <span>LinkedIn</span>}
    </a>

    <!-- Native share (mobile) — shown only if Web Share API available -->
    <button
      class="share-btn share-btn--native"
      data-share-title={title}
      data-share-url={url}
      aria-label="More sharing options"
      type="button"
      hidden
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
      {variant === 'full' && <span>More</span>}
    </button>
  </div>
</div>

<script>
  // Reveal native share button if Web Share API is available
  document.querySelectorAll( '[data-share-url]' ).forEach( btn => {
    if ( navigator.share ) {
      btn.removeAttribute( 'hidden' );
      btn.addEventListener( 'click', async () => {
        try {
          await navigator.share( {
            title: btn.dataset.shareTitle,
            url:   btn.dataset.shareUrl,
          } );
        } catch ( e ) {
          // User cancelled — not an error
        }
      } );
    }
  } );
</script>

<style>
  .share-bar { margin: var(--spacing) 0; }
  .share-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }
  .share-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    color: white;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }
  .share-bar--full .share-btn { padding: 0.5rem 0.875rem; }
  .share-btn:hover { opacity: 0.85; }
  .share-btn--x      { background: #000; }
  .share-btn--fb     { background: #1877f2; }
  .share-btn--wa     { background: #25d366; }
  .share-btn--li     { background: #0a66c2; }
  .share-btn--native { background: var(--color-muted); color: var(--color-text); }
</style>
