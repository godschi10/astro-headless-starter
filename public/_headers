# _headers — G-will Chijioke (https://gwillchijioke.com)
#
# Security headers for Cloudflare Pages.
#
# CSP NOTES:
#   - Dark mode script is now an external file (/js/darkmode.js).
#     script-src 'self' covers it. No hash needed.
#
#   - Matomo (when enabled): Astro's define:vars wraps it in an IIFE that
#     changes the script hash on every build. When you enable Matomo, either:
#     (a) Add 'unsafe-inline' to script-src temporarily while you extract the hash, OR
#     (b) Move Matomo to an external /js/matomo-init.js file (recommended).
#     Then remove 'unsafe-inline' and redeploy.
#
#   - connect-src: update when you add Matomo analytics or R2 CDN domain.
#     Add: https://analytics.yourdomain.com
#
#   - AdSense: uncomment the AdSense CSP block below when ENABLE_ADSENSE=true.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Cross-Origin-Opener-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://gwillchijioke.qzz.io; frame-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

  # AdSense CSP — uncomment when ENABLE_ADSENSE=true (replace line above):
  # Content-Security-Policy: default-src 'self'; script-src 'self' https://pagead2.googlesyndication.com https://partner.googleadservices.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://gwillchijioke.qzz.io https://pagead2.googlesyndication.com; frame-src https://googleads.g.doubleclick.net; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# Immutable cache for hashed Astro assets (content hash in filename = safe forever)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Dark mode init script — long cache, rarely changes
/js/darkmode.js
  Cache-Control: public, max-age=86400

# Short-lived for search index (rebuilt on each deploy)
/search-index.json
  Cache-Control: public, max-age=3600

# Sitemap and RSS
/sitemap.xml
  Cache-Control: public, max-age=3600
/rss.xml
  Cache-Control: public, max-age=3600
