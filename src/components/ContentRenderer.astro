---
/**
 * ContentRenderer.astro — G-will Chijioke (https://gwillchijioke.com)
 *
 * Sanitizes WP post HTML, injects heading IDs, generates TOC,
 * and renders content. TOC is disabled via TOC_EXCLUDED_IDS in config.ts.
 */
import { serverSanitizeHtml } from '../lib/server-sanitize';
import { TOC_EXCLUDED_IDS } from '../lib/config';

interface Props {
  content:       string;
  postId?:       number;
  class?:        string;
  enableToc?:    boolean;
}

const {
  content,
  postId    = 0,
  class: className = '',
  enableToc = true,
} = Astro.props;

// ── Sanitize first ────────────────────────────────────────────────────────────
const sanitized = serverSanitizeHtml( content );

// ── TOC generation ────────────────────────────────────────────────────────────
interface TocItem {
  id:    string;
  text:  string;
  level: number;
}

const tocItems: TocItem[] = [];
const showToc = enableToc && !TOC_EXCLUDED_IDS.includes( postId );

// Inject IDs into H2 and H3 headings, build TOC list
let processedContent = sanitized;

if ( showToc ) {
  let h2Count = 0;

  processedContent = sanitized.replace(
    /<(h[23])([^>]*)>([\s\S]*?)<\/h[23]>/gi,
    ( match, tag, attrs, innerHtml ) => {
      // Strip existing HTML tags from heading text for the TOC label
      const text = innerHtml.replace( /<[^>]+>/g, '' ).trim();
      if ( !text ) return match;

      // Build slug from text
      const slug = text
        .toLowerCase()
        .replace( /[^\w\s-]/g, '' )
        .replace( /\s+/g, '-' )
        .replace( /-+/g, '-' )
        .slice( 0, 60 );

      const id = `heading-${ slug }`;
      const level = parseInt( tag.slice( 1 ), 10 );

      // Only add H2s to TOC; H3s get IDs but no TOC entry (keeps TOC lean)
      if ( level === 2 ) {
        h2Count++;
        tocItems.push( { id, text, level } );
      }

      return `<${ tag }${ attrs } id="${ id }">${ innerHtml }</${ tag }>`;
    }
  );
}
---

{showToc && tocItems.length >= 3 && (
  <nav class="toc" aria-label="Table of contents" data-toc>
    <button class="toc-toggle" aria-expanded="true" aria-controls="toc-list" type="button">
      <span>Contents</span>
      <svg class="toc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </button>
    <ol id="toc-list" class="toc-list">
      {tocItems.map( ( item ) => (
        <li class="toc-item">
          <a href={`#${ item.id }`} class="toc-link" data-toc-link={item.id}>
            {item.text}
          </a>
        </li>
      ) )}
    </ol>
  </nav>
)}

<div class={`content-renderer prose ${ className }`} set:html={processedContent} />

<script>
  // ── TOC toggle ──────────────────────────────────────────────────────────────
  const toc    = document.querySelector( '[data-toc]' );
  const toggle = toc?.querySelector( '.toc-toggle' );
  const list   = document.getElementById( 'toc-list' );

  toggle?.addEventListener( 'click', () => {
    const expanded = toggle.getAttribute( 'aria-expanded' ) === 'true';
    toggle.setAttribute( 'aria-expanded', String( !expanded ) );
    if ( list ) list.hidden = expanded;
  } );

  // ── TOC active link on scroll ───────────────────────────────────────────────
  const tocLinks = document.querySelectorAll( '[data-toc-link]' );
  if ( tocLinks.length ) {
    const headings = Array.from( tocLinks ).map( link => {
      const id = link.dataset.tocLink;
      return { link, el: document.getElementById( id ) };
    } ).filter( h => h.el );

    let rafId: ReturnType<typeof requestAnimationFrame>;
    const onScroll = () => {
      cancelAnimationFrame( rafId );
      rafId = requestAnimationFrame( () => {
        const scrollY = window.scrollY + 120;
        let active = headings[0];
        for ( const h of headings ) {
          if ( h.el.offsetTop <= scrollY ) active = h;
        }
        tocLinks.forEach( l => l.classList.remove( 'is-active' ) );
        active?.link.classList.add( 'is-active' );
      } );
    };

    window.addEventListener( 'scroll', onScroll, { passive: true } );
    onScroll();
  }

  // ── Content enhancements ─────────────────────────────────────────────────────
  document.querySelectorAll( '.content-renderer' ).forEach( renderer => {
    // Wrap tables for responsive scroll
    renderer.querySelectorAll( 'table' ).forEach( table => {
      if ( table.parentElement?.classList.contains( 'table-wrapper' ) ) return;
      const wrapper = document.createElement( 'div' );
      wrapper.className = 'table-wrapper';
      table.parentNode?.insertBefore( wrapper, table );
      wrapper.appendChild( table );
    } );

    // Lazy-load images that don't have loading attribute
    renderer.querySelectorAll( 'img:not([loading])' ).forEach( img => {
      img.setAttribute( 'loading', 'lazy' );
      img.setAttribute( 'decoding', 'async' );
    } );

    // External links: noopener noreferrer + new tab
    renderer.querySelectorAll( 'a[href^="http"]' ).forEach( link => {
      if ( !link.hasAttribute( 'target' ) ) {
        link.setAttribute( 'target', '_blank' );
        link.setAttribute( 'rel', 'noopener noreferrer' );
      }
    } );
  } );
</script>

<style is:global>
  /* ── TOC ─────────────────────────────────────────────────────────────────── */
  .toc {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    margin: calc(var(--spacing) * 2) 0;
    font-size: 0.9375rem;
  }
  .toc-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    padding: 0;
    gap: 0.5rem;
  }
  .toc-toggle[aria-expanded="false"] .toc-chevron {
    transform: rotate(-90deg);
  }
  .toc-chevron { transition: transform var(--transition-base); }
  .toc-list {
    margin: 0.75rem 0 0;
    padding-left: 1.25rem;
    list-style: decimal;
  }
  .toc-item { margin: 0.25rem 0; }
  .toc-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    line-height: 1.5;
  }
  .toc-link:hover,
  .toc-link.is-active { color: var(--color-primary); }
  .toc-link.is-active { font-weight: 500; }

  /* ── Content ─────────────────────────────────────────────────────────────── */
  .content-renderer { line-height: 1.75; }
  .content-renderer > * + * { margin-top: 1.25em; }
  .content-renderer h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-text);
    scroll-margin-top: 80px;
  }
  .content-renderer h3 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 1.75em;
    margin-bottom: 0.5em;
    color: var(--color-text);
    scroll-margin-top: 80px;
  }
  .content-renderer h4 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5em;
    color: var(--color-text);
  }
  .content-renderer p   { color: var(--color-text); }
  .content-renderer a   { color: var(--color-primary); text-decoration: underline; text-underline-offset: 2px; }
  .content-renderer a:hover { text-decoration: none; }
  .content-renderer img { max-width: 100%; height: auto; border-radius: var(--radius-md); }
  .content-renderer blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: 1rem;
    margin-left: 0;
    font-style: italic;
    color: var(--color-text-muted);
  }
  .content-renderer code {
    background: var(--color-muted);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.875em;
    font-family: var(--font-mono);
  }
  .content-renderer pre {
    background: var(--color-code-bg);
    padding: 1rem;
    border-radius: var(--radius-md);
    overflow-x: auto;
  }
  .content-renderer pre code { background: none; padding: 0; }
  .content-renderer ul,
  .content-renderer ol { padding-left: 1.5rem; }
  .content-renderer li { margin-bottom: 0.375rem; }
  .content-renderer table { width: 100%; border-collapse: collapse; font-size: 0.9375rem; }
  .content-renderer th,
  .content-renderer td { padding: 0.625rem; border: 1px solid var(--color-border); text-align: left; }
  .content-renderer th { background: var(--color-muted); font-weight: 600; }
  .content-renderer figure { margin: 1.5rem 0; }
  .content-renderer figcaption {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }
  .table-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; }
</style>
