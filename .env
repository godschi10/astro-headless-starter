# ═══════════════════════════════════════════════════════════════════════════════
# Astro Headless Starter — G-will Chijioke (https://gwillchijioke.com)
# Copy to .env and fill in your values. Never commit .env to source control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Site identity ─────────────────────────────────────────────────────────────
SITE_URL=https://gwillchijioke.qzz.io
SITE_NAME=Your Site Name
SITE_DESC=Your site tagline here
SITE_LANG=en

# ── WordPress connection ──────────────────────────────────────────────────────
# Primary: WPGraphQL (recommended for complex nested data)
WP_GRAPHQL_URL=https://yourwp.com/graphql

# Fallback / additional REST calls
WP_REST_URL=https://yourwp.com/wp-json/wp/v2

# Application password (create in WP admin → Tools → Headless API Keys)
WP_USER=Gwill
WP_APP_PASS=Kgec EKSm pRxh T7E5 eFUt rYKb

# ── Author (single-author site) ───────────────────────────────────────────────
AUTHOR_NAME=Your Name
AUTHOR_BIO=A short bio about you.
AUTHOR_PAGE=/about
AUTHOR_TWITTER=https://x.com/yourhandle
AUTHOR_INSTAGRAM=
AUTHOR_EMAIL=you@example.com

# ── Media CDN ─────────────────────────────────────────────────────────────────
ENABLE_R2_IMAGES=false
R2_PUBLIC_URL=https://images.androidscroll.com

# ── Comments ──────────────────────────────────────────────────────────────────
ENABLE_COMMENTS=true
# Comments POST endpoint — the WP REST API URL (no CF Worker needed)
COMMENTS_ENDPOINT=https://gwillchijioke.qzz.io/wp-json/headless/v1/comments

# ── Forms ─────────────────────────────────────────────────────────────────────
FORM_ENDPOINT=https://gwillchijioke.qzz.io/wp-json/headless/v1/forms/submit

# ── Search ────────────────────────────────────────────────────────────────────
# Public URL for the server-side search fallback — intentionally exposed.
# The endpoint is read-only and unauthenticated.
PUBLIC_WP_SEARCH_URL=https://gwillchijioke.qzz.io/wp-json/headless/v1/search

# ── Analytics (Matomo) ───────────────────────────────────────────────────────
MATOMO_URL=https://analytics.androidscroll.com
MATOMO_SITE_ID=1

# ── AdSense (dormant until you enable) ───────────────────────────────────────
ENABLE_ADSENSE=false
ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXXX
ADSENSE_SLOT_INARTICLE=
ADSENSE_SLOT_SIDEBAR=
ADSENSE_SLOT_BELOWPOST=
ADSENSE_SLOT_INFEED=

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_DARKMODE=true

# ── Build performance ─────────────────────────────────────────────────────────
CACHE_TTL=300000
BUILD_CONCURRENCY=15

# ── Homepage pinned content (WP post databaseIds) ─────────────────────────────
# Set to specific post IDs after you publish content.
# Leave as 0 to use the latest posts automatically.
FEATURED_POST_ID=0
# Comma-separated list: POPULAR_POST_IDS=42,7,99
POPULAR_POST_IDS=42
