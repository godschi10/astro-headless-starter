---
// FormApplication — G-will Chijioke (https://gwillchijioke.com)
const endpoint = import.meta.env.FORM_ENDPOINT || '';
const honeypot = import.meta.env.FORM_HONEYPOT_FIELD || 'website';
---

<form
  class="form-application"
  data-endpoint={endpoint}
  data-honeypot={honeypot}
  novalidate
>
  <div class="form-row">
    <div class="form-group">
      <label for="fa-name">Full Name <span aria-hidden="true">*</span></label>
      <input type="text" id="fa-name" name="name" required autocomplete="name" />
    </div>
    <div class="form-group">
      <label for="fa-email">Email <span aria-hidden="true">*</span></label>
      <input type="email" id="fa-email" name="email" required autocomplete="email" />
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="fa-role">Role Applying For <span aria-hidden="true">*</span></label>
      <select id="fa-role" name="role" required>
        <option value="">Select a role</option>
        <option value="frontend-dev">Frontend Developer</option>
        <option value="wp-dev">WordPress Developer</option>
        <option value="seo-specialist">SEO Specialist</option>
        <option value="content-writer">Content Writer</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div class="form-group">
      <label for="fa-experience">Years of Experience <span aria-hidden="true">*</span></label>
      <select id="fa-experience" name="experience" required>
        <option value="">Select</option>
        <option value="0-1">0 – 1 year</option>
        <option value="1-3">1 – 3 years</option>
        <option value="3-5">3 – 5 years</option>
        <option value="5-plus">5+ years</option>
      </select>
    </div>
  </div>

  <div class="form-group">
    <label for="fa-portfolio">Portfolio / GitHub URL</label>
    <input type="url" id="fa-portfolio" name="portfolio" placeholder="https://" />
  </div>

  <div class="form-group">
    <label for="fa-availability">Availability <span aria-hidden="true">*</span></label>
    <select id="fa-availability" name="availability" required>
      <option value="">Select</option>
      <option value="fulltime">Full-time</option>
      <option value="parttime">Part-time</option>
      <option value="contract">Contract / Project-based</option>
      <option value="internship">Internship</option>
    </select>
  </div>

  <div class="form-group">
    <label for="fa-cover">Cover Letter <span aria-hidden="true">*</span></label>
    <textarea id="fa-cover" name="message" rows="6" required placeholder="Tell us about yourself and why you'd be a good fit…"></textarea>
  </div>

  <!-- Honeypot -->
  <div class="form-honeypot" aria-hidden="true">
    <input type="text" name={honeypot} tabindex="-1" autocomplete="off" />
  </div>

  <div class="form-status" role="status" aria-live="polite"></div>

  <button type="submit" class="form-submit">
    <span class="btn-label">Submit Application</span>
    <span class="btn-loading" hidden>Submitting…</span>
  </button>
</form>

<style>
  .form-application { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: .375rem; }
  .form-group label { font-size: .875rem; font-weight: 500; }
  .form-group label span { color: var(--color-accent, #e53e3e); }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%; padding: .625rem .75rem;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: .375rem; font-size: 1rem;
    background: var(--color-surface, #fff);
    color: var(--color-text, #111); transition: border-color .15s;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none; border-color: var(--color-accent, #3b82f6);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent, #3b82f6) 20%, transparent);
  }
  .form-honeypot { display: none; }
  .form-status { font-size: .875rem; min-height: 1.25rem; }
  .form-status.success { color: #16a34a; }
  .form-status.error   { color: #dc2626; }
  .form-submit {
    align-self: flex-start; padding: .625rem 1.5rem;
    background: var(--color-accent, #3b82f6);
    color: #fff; border: none; border-radius: .375rem;
    font-size: 1rem; font-weight: 500; cursor: pointer; transition: opacity .15s;
  }
  .form-submit:disabled { opacity: .6; cursor: not-allowed; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('.form-application');
  if (form) {
    const endpoint  = form.dataset.endpoint || '';
    const honeypot  = form.dataset.honeypot || 'website';
    const status    = form.querySelector<HTMLElement>('.form-status')!;
    const label     = form.querySelector<HTMLElement>('.btn-label')!;
    const loading   = form.querySelector<HTMLElement>('.btn-loading')!;
    const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!endpoint) { status.textContent = 'Form endpoint not configured.'; status.className = 'form-status error'; return; }
      const data = Object.fromEntries(new FormData(form));
      if (data[honeypot]) return;

      label.hidden = true; loading.hidden = false; submitBtn.disabled = true;
      status.textContent = ''; status.className = 'form-status';

      try {
        const nonceRes = await fetch(endpoint.replace('/forms/submit', '/nonce'));
        const { nonce } = await nonceRes.json();
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-WP-Nonce': nonce },
          body: JSON.stringify({ form_id: 'application', fields: data }),
        });
        const result = await res.json();
        status.textContent = result.message || (result.success ? 'Application submitted!' : 'Something went wrong.');
        status.className   = 'form-status ' + (result.success ? 'success' : 'error');
        if (result.success) form.reset();
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className   = 'form-status error';
      } finally {
        label.hidden = false; loading.hidden = true; submitBtn.disabled = false;
      }
    });
  }
</script>
