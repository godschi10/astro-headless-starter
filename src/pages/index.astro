---
// Homepage — G-will Chijioke (https://gwillchijioke.com)
import Layout from '../layouts/Layout.astro';
import Image from '../components/Image.astro';
import { gqlClient } from '../lib/wp/client';
import { GET_POSTS, GET_CATEGORIES } from '../lib/wp/queries';
import { cached } from '../lib/cache';
import { SITE_NAME, SITE_URL } from '../lib/config';

const posts = await cached('homepage-posts', async () => {
  if (!gqlClient) return [];
  const data = await gqlClient.request(GET_POSTS, { first: 6 });
  return data.posts?.nodes || [];
}, 300000);

const categories = await cached('homepage-categories', async () => {
  if (!gqlClient) return [];
  const data = await gqlClient.request(GET_CATEGORIES);
  return data.categories?.nodes || [];
}, 300000);

const featuredPost = posts[0];
const recentPosts = posts.slice(1, 6);
---

<Layout
  title={SITE_NAME}
  description={`Latest articles and insights from ${SITE_NAME}`}
  canonical={SITE_URL}
  type="website"
>
  <div class="homepage">
    <!-- Hero -->
    {featuredPost && (
      <section class="hero">
        <a href={`/${featuredPost.slug}`} class="hero-link">
          {featuredPost.featuredImage?.node && (
            <Image
              src={featuredPost.featuredImage.node.sourceUrl}
              alt={featuredPost.featuredImage.node.altText || featuredPost.title}
              width={featuredPost.featuredImage.node.mediaDetails?.width}
              height={featuredPost.featuredImage.node.mediaDetails?.height}
              loading="eager"
              fetchpriority="high"
              r2Url={featuredPost.featuredImage.node.r2Url}
              modernFormats={featuredPost.featuredImage.node.modernFormats}
            />
          )}
          <div class="hero-content">
            <span class="hero-label">Featured</span>
            <h1 class="hero-title">{featuredPost.title}</h1>
            <p class="hero-excerpt">{featuredPost.excerpt?.replace(/<[^>]+>/g, '').trim()}</p>
            <span class="hero-read">Read article &rarr;</span>
          </div>
        </a>
      </section>
    )}

    <!-- Recent Posts -->
    <section class="recent-posts">
      <h2 class="section-title">Latest Articles</h2>
      <div class="post-grid">
        {recentPosts.map(post => (
          <article class="post-card">
            <a href={`/${post.slug}`} class="post-card-link">
              {post.featuredImage?.node && (
                <Image
                  src={post.featuredImage.node.sourceUrl}
                  alt={post.featuredImage.node.altText || post.title}
                  width={400}
                  height={250}
                  class="post-card-image"
                  r2Url={post.featuredImage.node.r2Url}
                  modernFormats={post.featuredImage.node.modernFormats}
                />
              )}
              <div class="post-card-content">
                <h3 class="post-card-title">{post.title}</h3>
                <p class="post-card-excerpt">{post.excerpt?.replace(/<[^>]+>/g, '').trim()}</p>
                <div class="post-card-meta">
                  <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                  {post.readingTime && <span>{post.readingTime} min read</span>}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    <!-- Categories -->
    <section class="categories-section">
      <h2 class="section-title">Browse by Topic</h2>
      <div class="category-grid">
        {categories.filter(c => c.count > 0).map(cat => (
          <a href={`/category/${cat.slug}`} class="category-card">
            <span class="category-name">{cat.name}</span>
            <span class="category-count">{cat.count} articles</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .homepage {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing) var(--gutter);
  }
  .hero {
    margin-bottom: calc(var(--spacing) * 3);
  }
  .hero-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s;
  }
  .hero-link:hover {
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.15);
  }
  .hero-link :global(.responsive-image) {
    margin: 0;
  }
  .hero-link :global(.responsive-image img) {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 0;
  }
  .hero-content {
    padding: calc(var(--spacing) * 1.5);
  }
  .hero-label {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    line-height: 1.2;
    color: var(--color-text);
  }
  .hero-excerpt {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    line-height: 1.6;
  }
  .hero-read {
    color: var(--color-primary);
    font-weight: 600;
  }
  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: calc(var(--spacing) * 1.5);
    color: var(--color-text);
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: calc(var(--spacing) * 1.5);
    margin-bottom: calc(var(--spacing) * 3);
  }
  .post-card {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .post-card:hover {
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .post-card :global(.responsive-image) {
    margin: 0;
  }
  .post-card :global(.responsive-image img) {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0;
  }
  .post-card-content {
    padding: var(--spacing);
  }
  .post-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    line-height: 1.3;
    color: var(--color-text);
  }
  .post-card-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing);
  }
  .category-card {
    display: flex;
    flex-direction: column;
    padding: calc(var(--spacing) * 1.25);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .category-card:hover {
    background: var(--color-muted);
    border-color: var(--color-primary);
  }
  .category-name {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .category-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 640px) {
    .hero-link :global(.responsive-image img) {
      height: 250px;
    }
    .hero-title {
      font-size: 1.5rem;
    }
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
