---
// Dark mode toggle — G-will Chijioke (https://gwillchijioke.com)
---

<button
  class="darkmode-toggle"
  aria-label="Toggle dark mode"
  data-darkmode-toggle
  type="button"
>
  <span class="darkmode-icon light" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
  </span>
  <span class="darkmode-icon dark" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </span>
</button>

<script>
  const STORAGE_KEY = 'headless-color-scheme';
  const toggle = document.querySelector('[data-darkmode-toggle]');
  const html = document.documentElement;

  function getStoredScheme() {
    try { return localStorage.getItem(STORAGE_KEY); } catch { return null; }
  }

  function setScheme(scheme) {
    if (scheme === 'system') {
      localStorage.removeItem(STORAGE_KEY);
      html.removeAttribute('data-theme');
    } else {
      localStorage.setItem(STORAGE_KEY, scheme);
      html.dataset.theme = scheme;
    }
    updateIcon();
  }

  function updateIcon() {
    const stored = getStoredScheme();
    const isDark = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
    toggle?.classList.toggle('is-dark', isDark);
  }

  toggle?.addEventListener('click', () => {
    const stored = getStoredScheme();
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const current = stored || (systemDark ? 'dark' : 'light');
    setScheme(current === 'dark' ? 'light' : 'dark');
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (!getStoredScheme()) updateIcon();
  });

  updateIcon();
</script>

<style>
  .darkmode-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    /* Minimum 44×44px tap target — WCAG 2.5.5 */
    min-width: 44px;
    min-height: 44px;
    /* Explicit position so z-index is honoured if needed */
    position: relative;
    z-index: 1;
  }
  .darkmode-toggle:hover {
    background: var(--color-muted);
  }
  .darkmode-icon {
    display: none;
  }
  .darkmode-toggle:not(.is-dark) .light,
  .darkmode-toggle.is-dark .dark {
    display: block;
  }
</style>
