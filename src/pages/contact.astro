---
// Contact page — G-will Chijioke (https://gwillchijioke.com)
import Layout from '../layouts/Layout.astro';
import FormSimple from '../components/forms/FormSimple.astro';
import FormInquiry from '../components/forms/FormInquiry.astro';
import FormRouted from '../components/forms/FormRouted.astro';
import FormMultistep from '../components/forms/FormMultistep.astro';
import FormApplication from '../components/forms/FormApplication.astro';
import FormPartnership from '../components/forms/FormPartnership.astro';
import { SITE_NAME, SITE_URL } from '../lib/config';

// In production, fetch form type from WP custom field
const formType = 'simple';

const formComponents: Record<string, any> = {
  simple: FormSimple,
  inquiry: FormInquiry,
  routed: FormRouted,
  multistep: FormMultistep,
  application: FormApplication,
  partnership: FormPartnership,
};

const SelectedForm = formComponents[formType] || FormSimple;
---

<Layout
  title={`Contact — ${SITE_NAME}`}
  description={`Get in touch with ${SITE_NAME}`}
  canonical={`${SITE_URL}/contact`}
  type="website"
>
  <div class="contact-page">
    <h1 class="page-title">Contact Us</h1>
    <p class="page-desc">Have a question or project in mind? We'd love to hear from you.</p>
    <div class="contact-form-wrapper">
      <SelectedForm />
    </div>
  </div>
</Layout>

<style>
  .contact-page {
    max-width: 640px;
    margin: 0 auto;
    padding: calc(var(--spacing) * 2) var(--gutter);
  }
  .page-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .page-desc {
    color: var(--color-text-muted);
    margin: 0 0 calc(var(--spacing) * 2);
    font-size: 1.0625rem;
  }
  .contact-form-wrapper {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: calc(var(--spacing) * 1.5);
  }
</style>
