---
// Search page — G-will Chijioke (https://gwillchijioke.com)
import Layout from '../layouts/Layout.astro';
import Image from '../components/Image.astro';
import { SITE_NAME, SITE_URL } from '../lib/config';

const query = Astro.url.searchParams.get('q') || '';
let results: any[] = [];
let total = 0;

if (query) {
  try {
    const WP_REST_URL = import.meta.env.WP_REST_URL;
    const res = await fetch(
      `${WP_REST_URL}/headless/v1/search?s=${encodeURIComponent(query)}&per_page=20`,
      { headers: { 'Content-Type': 'application/json' } }
    );
    const data = await res.json();
    results = data.results || [];
    total = data.total || 0;
  } catch (e) {
    console.warn('[Search] Failed:', e);
  }
}
---

<Layout
  title={query ? `Search: ${query} — ${SITE_NAME}` : `Search — ${SITE_NAME}`}
  description={`Search results for "${query}" on ${SITE_NAME}`}
  canonical={`${SITE_URL}/search${query ? `?q=${encodeURIComponent(query)}` : ''}`}
  type="website"
>
  <div class="search-page">
    <h1 class="page-title">
      {query ? `Search Results` : 'Search'}
    </h1>

    {query && (
      <p class="search-stats">
        {total > 0 ? `${total} result${total !== 1 ? 's' : ''} for "${query}"` : `No results for "${query}"`}
      </p>
    )}

    {!query && (
      <div class="search-empty">
        <p>Enter a search term above to find articles.</p>
      </div>
    )}

    <div class="search-results-list">
      {results.map(result => (
        <article class="search-result-item">
          <a href={`/${result.slug}`} class="search-result-link">
            <div class="search-result-content">
              <h2 class="search-result-title">{result.title}</h2>
              <p class="search-result-excerpt">{result.excerpt}</p>
              <div class="search-result-meta">
                <time datetime={result.date}>
                  {new Date(result.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <span class="search-result-type">{result.post_type}</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</Layout>

<style>
  .search-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: calc(var(--spacing) * 2) var(--gutter);
  }
  .page-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .search-stats {
    color: var(--color-text-muted);
    margin: 0 0 calc(var(--spacing) * 2);
  }
  .search-empty {
    text-align: center;
    padding: calc(var(--spacing) * 3);
    color: var(--color-text-muted);
  }
  .search-results-list {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 1.5);
  }
  .search-result-item {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .search-result-item:hover {
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.1);
  }
  .search-result-link {
    display: block;
    padding: var(--spacing);
    text-decoration: none;
    color: inherit;
  }
  .search-result-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .search-result-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }
  .search-result-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .search-result-type {
    text-transform: capitalize;
  }
</style>
