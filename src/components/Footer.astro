---
/**
 * Footer.astro — G-will Chijioke (https://gwillchijioke.com)
 */
import { SITE_NAME, FOOTER_LINKS } from '../lib/config';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="copyright">
      &copy; {year} {SITE_NAME}. All rights reserved.
    </p>
    <nav class="footer-nav" aria-label="Footer navigation">
      {FOOTER_LINKS.map( ( link ) => (
        <a href={link.href} class="footer-link">{link.label}</a>
      ) )}
    </nav>
  </div>
  <p class="author-credit">
    Built by <a href="https://gwillchijioke.com" target="_blank" rel="noopener noreferrer">G-will Chijioke</a>
  </p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: calc(var(--spacing) * 2) var(--gutter);
    margin-top: auto;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing);
    flex-wrap: wrap;
  }
  .footer-nav {
    display: flex;
    gap: calc(var(--spacing) * 0.75);
    flex-wrap: wrap;
  }
  .footer-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition-fast);
  }
  .footer-link:hover { color: var(--color-text); }
  .copyright {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }
  .author-credit {
    max-width: var(--max-width);
    margin: calc(var(--spacing) * 0.75) auto 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-align: center;
  }
  .author-credit a {
    color: var(--color-primary);
  }
  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; text-align: center; }
  }
</style>
