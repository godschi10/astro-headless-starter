---
// Privacy Policy page — G-will Chijioke (https://gwillchijioke.com)
import Layout from '../layouts/Layout.astro';
import { SITE_NAME, SITE_URL } from '../lib/config';

const lastUpdated = '2025-01-01';
---

<Layout
  title={`Privacy Policy — ${SITE_NAME}`}
  description={`Privacy policy for ${SITE_NAME} — how we collect, use, and protect your information.`}
  canonical={`${SITE_URL}/privacy`}
>
  <div class="privacy-page">
    <div class="container">
      <header class="page-header">
        <h1>Privacy Policy</h1>
        <p class="last-updated">Last updated: <time datetime={lastUpdated}>{lastUpdated}</time></p>
      </header>

      <div class="privacy-content">

        <section>
          <h2>1. Information We Collect</h2>
          <p>We collect information you provide directly, such as when you submit a contact form or post a comment. This may include your name, email address, and message content.</p>
          <p>We also collect standard server log data including IP addresses, browser type, pages visited, and timestamps. This data is used to maintain site security and analyse traffic patterns.</p>
        </section>

        <section>
          <h2>2. Comments</h2>
          <p>When you submit a comment, your name, email address, and comment content are collected. Your email address is not displayed publicly. Comments may be held for moderation before appearing on the site.</p>
        </section>

        <section>
          <h2>3. Contact Forms</h2>
          <p>Information submitted via contact forms is used solely to respond to your enquiry. We do not sell, rent, or share your contact details with third parties.</p>
        </section>

        <section>
          <h2>4. Cookies</h2>
          <p>This site uses a single functional cookie to store your dark/light mode preference (<code>headless-color-scheme</code>). No tracking or advertising cookies are used.</p>
          <p>If analytics are enabled, an analytics cookie may be set to help us understand aggregate site usage. No personally identifiable information is stored in these cookies.</p>
        </section>

        <section>
          <h2>5. Third-Party Services</h2>
          <p>This site may link to external websites. We are not responsible for the privacy practices of those sites and encourage you to review their policies.</p>
          <p>Images may be served from Cloudflare R2. Cloudflare's privacy policy applies to those requests.</p>
        </section>

        <section>
          <h2>6. Data Retention</h2>
          <p>Contact form submissions are retained only as long as necessary to respond to your enquiry. Comment data is retained for the lifetime of the published post it accompanies.</p>
        </section>

        <section>
          <h2>7. Your Rights</h2>
          <p>You have the right to request access to, correction of, or deletion of any personal data we hold about you. To make a request, use the <a href="/contact">contact form</a>.</p>
        </section>

        <section>
          <h2>8. Changes to This Policy</h2>
          <p>We may update this policy from time to time. The date at the top of this page reflects the most recent revision. Continued use of the site after changes constitutes acceptance of the updated policy.</p>
        </section>

      </div>
    </div>
  </div>
</Layout>

<style>
  .privacy-page {
    padding: calc( var(--spacing) * 4 ) 0;
  }
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--spacing);
  }
  .page-header {
    margin-bottom: calc( var(--spacing) * 3 );
    border-bottom: 1px solid var(--color-border);
    padding-bottom: calc( var(--spacing) * 2 );
  }
  .page-header h1 {
    font-size: clamp( 1.75rem, 4vw, 2.5rem );
    margin: 0 0 0.5rem;
  }
  .last-updated {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }
  .privacy-content {
    display: flex;
    flex-direction: column;
    gap: calc( var(--spacing) * 2.5 );
  }
  .privacy-content section h2 {
    font-size: 1.125rem;
    margin: 0 0 0.75rem;
    color: var(--color-heading, var(--color-text));
  }
  .privacy-content section p {
    margin: 0 0 0.75rem;
    line-height: 1.7;
    color: var(--color-text);
  }
  .privacy-content section p:last-child {
    margin-bottom: 0;
  }
  .privacy-content a {
    color: var(--color-accent);
    text-decoration: underline;
  }
  code {
    font-family: monospace;
    font-size: 0.875em;
    background: var(--color-muted);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
</style>
