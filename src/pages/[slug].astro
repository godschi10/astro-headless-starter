---
/**
 * [slug].astro — G-will Chijioke (https://gwillchijioke.com)
 * Single post and page template.
 */
import Layout from '../layouts/Layout.astro';
import ContentRenderer from '../components/ContentRenderer.astro';
import Comments from '../components/Comments.astro';
import Image from '../components/Image.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ShareBar from '../components/ShareBar.astro';
import AuthorBox from '../components/AuthorBox.astro';
import AdSlot from '../components/AdSlot.astro';
import { gqlClient } from '../lib/wp/client';
import { GET_POST_BY_SLUG, GET_PAGE_BY_SLUG, GET_POSTS } from '../lib/wp/queries';
import { cached } from '../lib/cache';
import { seoFromWp } from '../lib/seo';
import { ENABLE_COMMENTS, SITE_URL, SITE_NAME } from '../lib/config';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = ( async () => {
  if ( !gqlClient ) {
    throw new Error(
      '[slug] gqlClient is null — WP_GRAPHQL_URL must be set to generate post paths.'
    );
  }

  // Paginate through all posts
  let allPosts: any[] = [];
  let hasNextPage     = true;
  let after: string | null = null;

  while ( hasNextPage ) {
    const data: any = await cached( `all-posts-slugs-${ after || 'start' }`, async () => {
      return gqlClient!.request( GET_POSTS, { first: 100, after } );
    }, 600000 );

    const nodes    = data.posts?.nodes    || [];
    const pageInfo = data.posts?.pageInfo || {};
    allPosts.push( ...nodes );
    hasNextPage = pageInfo.hasNextPage;
    after       = pageInfo.endCursor || null;
  }

  return allPosts.map( ( post: any ) => ( {
    params: { slug: post.slug },
    props:  { postType: 'post' as const },
  } ) );
} ) satisfies GetStaticPaths;

const { slug }     = Astro.params;
const { postType } = Astro.props;

// ── Fetch full post data ───────────────────────────────────────────────────────
let post: any = null;

try {
  if ( gqlClient ) {
    const data: any = await gqlClient.request( GET_POST_BY_SLUG, { slug } );
    post = data.post;
  }
} catch ( e ) {
  console.warn( `[slug] Post not found: ${ slug }` );
}

// Try as WP page if not found as post
if ( !post ) {
  try {
    if ( gqlClient ) {
      const data: any = await gqlClient.request( GET_PAGE_BY_SLUG, { slug } );
      post = data.page;
    }
  } catch ( e2 ) {
    console.warn( `[slug] Page not found: ${ slug }` );
  }
}

if ( !post ) return Astro.redirect( '/404' );

// ── Metadata ──────────────────────────────────────────────────────────────────
const title       = post.seo?.title       || post.title || '';
const description = post.seo?.description
  || ( typeof post.excerpt === 'string'
       ? post.excerpt.replace( /<[^>]+>/g, '' ).trim()
       : post.excerpt?.rendered?.replace( /<[^>]+>/g, '' ).trim() || '' );
const canonical   = post.seo?.canonical   || `${ SITE_URL }/${ slug }`;
const cover       = post.featuredImage?.node?.r2Url
                 || post.featuredImage?.node?.sourceUrl
                 || null;
const coverAlt    = post.featuredImage?.node?.altText || '';
const postId      = post.databaseId;

// ── Author ────────────────────────────────────────────────────────────────────
const authorNode  = post.author?.node;
const authorName  = authorNode?.name     || '';
const authorBio   = authorNode?.description || '';
const authorAvatar= authorNode?.avatar?.url || '';

// ── Post meta ─────────────────────────────────────────────────────────────────
const published   = post.date     || '';
const modified    = post.modified || '';
const readingTime = post.readingTime || 0;
const isPage      = post.__typename === 'Page' || !post.categories;

// ── Breadcrumbs ───────────────────────────────────────────────────────────────
const breadcrumbs = post.breadcrumbs?.length
  ? post.breadcrumbs
  : [
      { title: SITE_NAME, url: '/' },
      { title: post.title,  url: `/${ slug }` },
    ];

// ── Related posts (same first category, exclude current) ─────────────────────
let relatedPosts: any[] = [];
if ( !isPage ) {
  try {
    const firstCat = post.categories?.nodes?.[0];
    if ( firstCat && gqlClient ) {
      const relData: any = await cached( `related-${ firstCat.slug }`, async () => {
        const { GET_POSTS_BY_CATEGORY } = await import( '../lib/wp/queries' );
        return gqlClient!.request( GET_POSTS_BY_CATEGORY, {
          category: firstCat.name,
          first: 5,
        } );
      }, 300000 );

      relatedPosts = ( relData?.posts?.nodes || [] )
        .filter( ( p: any ) => p.slug !== slug )
        .slice( 0, 3 );
    }
  } catch ( e ) {
    console.warn( '[slug] Failed to fetch related posts:', e );
  }
}

// ── Comment schema ────────────────────────────────────────────────────────────
const commentSchema = ENABLE_COMMENTS ? {
  '@context':  'https://schema.org',
  '@type':     'BlogPosting',
  headline:     post.title,
  url:          canonical,
  datePublished:published,
  dateModified: modified,
  ...(authorName && { author: { '@type': 'Person', name: authorName } }),
  interactionStatistic: {
    '@type':           'InteractionCounter',
    interactionType:    { '@type': 'CommentAction' },
    userInteractionCount: 0,
  },
} : null;
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  cover={cover}
  coverAlt={coverAlt}
  type="article"
  noindex={post.seo?.noindex || false}
  authorName={authorName}
  published={published}
  modified={modified}
  commentSchema={commentSchema}
>
  <ReadingProgress />

  <article class="single-post">
    <div class="post-container">
      <Breadcrumbs crumbs={breadcrumbs} />

      <header class="post-header">
        {!isPage && post.categories?.nodes?.length > 0 && (
          <div class="post-categories">
            {post.categories.nodes.map( ( cat: any ) => (
              <a href={`/category/${ cat.slug }`} class="post-category-badge">
                {cat.name}
              </a>
            ) )}
          </div>
        )}

        <h1 class="post-title">{post.title}</h1>

        {!isPage && (
          <div class="post-meta">
            {authorName && <span class="post-author">By {authorName}</span>}
            <time datetime={published}>
              {new Date( published ).toLocaleDateString( 'en-US', {
                year: 'numeric', month: 'long', day: 'numeric'
              } )}
            </time>
            {readingTime > 0 && <span>{readingTime} min read</span>}
          </div>
        )}

        {!isPage && <ShareBar url={canonical} title={post.title} variant="compact" />}
      </header>

      {cover && (
        <Image
          src={cover}
          alt={coverAlt}
          width={post.featuredImage?.node?.mediaDetails?.width}
          height={post.featuredImage?.node?.mediaDetails?.height}
          loading="eager"
          fetchpriority="high"
          r2Url={post.featuredImage?.node?.r2Url}
          modernFormats={post.featuredImage?.node?.modernFormats}
        />
      )}

      <AdSlot slot="inArticle" />

      <ContentRenderer
        content={typeof post.content === 'string' ? post.content : post.content?.rendered || ''}
        postId={postId}
        enableToc={!isPage}
      />

      <AdSlot slot="belowPost" />

      {!isPage && (
        <div class="post-footer">
          {!isPage && post.tags?.nodes?.length > 0 && (
            <div class="post-tags">
              {post.tags.nodes.map( ( tag: any ) => (
                <a href={`/tag/${ tag.slug }`} class="post-tag">#{tag.name}</a>
              ) )}
            </div>
          )}

          <ShareBar url={canonical} title={post.title} variant="full" />

          <AuthorBox
            name={authorName}
            bio={authorBio}
            avatarUrl={authorAvatar}
          />
        </div>
      )}

      {!isPage && relatedPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-heading">
          <h2 id="related-heading" class="related-title">Related Articles</h2>
          <div class="related-grid">
            {relatedPosts.map( ( p: any ) => (
              <article class="related-card">
                <a href={`/${ p.slug }`} class="related-card-link">
                  {p.featuredImage?.node && (
                    <Image
                      src={p.featuredImage.node.r2Url || p.featuredImage.node.sourceUrl}
                      alt={p.featuredImage.node.altText || p.title}
                      width={400}
                      height={225}
                      r2Url={p.featuredImage.node.r2Url}
                      modernFormats={p.featuredImage.node.modernFormats}
                    />
                  )}
                  <div class="related-card-content">
                    <h3 class="related-card-title">{p.title}</h3>
                    {p.readingTime && (
                      <span class="related-card-meta">{p.readingTime} min read</span>
                    )}
                  </div>
                </a>
              </article>
            ) )}
          </div>
        </section>
      )}

      {ENABLE_COMMENTS && !isPage && (
        <Comments postId={postId} />
      )}
    </div>
  </article>
</Layout>

<style>
  .single-post {
    max-width: 768px;
    margin: 0 auto;
    padding: calc(var(--spacing) * 2) var(--gutter);
  }
  .post-header { margin-bottom: calc(var(--spacing) * 2); }
  .post-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .post-category-badge {
    display: inline-block;
    background: var(--color-primary-alpha);
    color: var(--color-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .post-title {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .post-author { font-weight: 500; color: var(--color-text); }
  .single-post :global(.responsive-image) { margin: calc(var(--spacing) * 2) 0; }
  .single-post :global(.responsive-image img) { width: 100%; border-radius: var(--radius-lg); }
  .post-footer { margin-top: calc(var(--spacing) * 2); }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--spacing);
  }
  .post-tag {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    background: var(--color-muted);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }
  .post-tag:hover { color: var(--color-primary); background: var(--color-primary-alpha); }
  .related-posts { margin-top: calc(var(--spacing) * 3); }
  .related-title {
    font-size: 1.375rem;
    font-weight: 700;
    margin-bottom: var(--spacing);
    color: var(--color-text);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--spacing);
  }
  .related-card {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }
  .related-card:hover { box-shadow: 0 8px 24px -6px rgba(0,0,0,0.1); }
  .related-card-link { display: block; text-decoration: none; color: inherit; }
  .related-card :global(.responsive-image) { margin: 0; }
  .related-card :global(.responsive-image img) {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 0;
  }
  .related-card-content { padding: 0.75rem; }
  .related-card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 0.375rem;
    line-height: 1.35;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-card-meta { font-size: 0.8125rem; color: var(--color-text-muted); }
  @media (max-width: 640px) {
    .post-title { font-size: 1.75rem; }
    .single-post { padding: var(--spacing) var(--gutter); }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
