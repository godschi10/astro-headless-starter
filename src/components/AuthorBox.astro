---
/**
 * AuthorBox.astro — G-will Chijioke (https://gwillchijioke.com)
 *
 * Displays author bio below post content.
 * Uses config.ts values for single-author sites.
 * Pass overrides when post has its own author node (multi-author).
 */
import {
  AUTHOR_NAME,
  AUTHOR_BIO,
  AUTHOR_PAGE,
  AUTHOR_TWITTER,
  AUTHOR_INSTAGRAM,
} from '../lib/config';

interface Props {
  name?:        string;
  bio?:         string;
  profileUrl?:  string;
  avatarUrl?:   string;
  twitter?:     string;
  instagram?:   string;
}

const {
  name       = AUTHOR_NAME,
  bio        = AUTHOR_BIO,
  profileUrl = AUTHOR_PAGE,
  avatarUrl  = '',
  twitter    = AUTHOR_TWITTER,
  instagram  = AUTHOR_INSTAGRAM,
} = Astro.props;

// Gravatar fallback if no avatar URL provided
const displayAvatar = avatarUrl
  || `https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&s=80`;
---

{name && (
  <aside class="author-box" aria-label="About the author">
    <div class="author-box-inner">
      <a href={profileUrl} class="author-avatar-link" aria-hidden="true" tabindex="-1">
        <img
          src={displayAvatar}
          alt=""
          class="author-avatar"
          width="64"
          height="64"
          loading="lazy"
          decoding="async"
        />
      </a>
      <div class="author-info">
        <p class="author-byline">Written by</p>
        <a href={profileUrl} class="author-name">{name}</a>
        {bio && <p class="author-bio">{bio}</p>}
        <div class="author-links">
          {twitter && (
            <a
              href={twitter}
              class="author-social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${ name } on X`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.258 5.626L18.244 2.25ZM17.08 18.75h1.833L6.988 4.126H5.024L17.08 18.75Z"/>
              </svg>
              X
            </a>
          )}
          {instagram && (
            <a
              href={instagram}
              class="author-social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${ name } on Instagram`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069ZM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z"/>
              </svg>
              Instagram
            </a>
          )}
          <a href={profileUrl} class="author-more-link">More articles →</a>
        </div>
      </div>
    </div>
  </aside>
)}

<style>
  .author-box {
    margin-top: calc(var(--spacing) * 3);
    padding: calc(var(--spacing) * 1.5);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .author-box-inner {
    display: flex;
    gap: calc(var(--spacing) * 1.25);
    align-items: flex-start;
  }
  .author-avatar-link { flex-shrink: 0; }
  .author-avatar {
    border-radius: 50%;
    width: 64px;
    height: 64px;
    object-fit: cover;
  }
  .author-byline {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem;
  }
  .author-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
  }
  .author-name:hover { color: var(--color-primary); }
  .author-bio {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }
  .author-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .author-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .author-social-link:hover { color: var(--color-primary); }
  .author-more-link {
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .author-more-link:hover { text-decoration: underline; }
  @media (max-width: 480px) {
    .author-box-inner { flex-direction: column; }
  }
</style>
