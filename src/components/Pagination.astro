---
// Pagination component — G-will Chijioke (https://gwillchijioke.com)
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;

function getPageUrl(page: number): string {
  if (page === 1) return basePath;
  return `${basePath}/page/${page}`;
}

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
const showEllipsisStart = currentPage > 3;
const showEllipsisEnd = currentPage < totalPages - 2;
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination">
    {currentPage > 1 && (
      <a href={getPageUrl(currentPage - 1)} class="pagination-prev" aria-label="Previous page">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
    )}

    <div class="pagination-pages">
      {showEllipsisStart && (
        <>
          <a href={getPageUrl(1)} class="pagination-page">1</a>
          <span class="pagination-ellipsis">...</span>
        </>
      )}

      {pages
        .filter(p => 
          p === 1 || 
          p === totalPages || 
          (p >= currentPage - 1 && p <= currentPage + 1)
        )
        .map(p => (
          <a
            href={getPageUrl(p)}
            class={`pagination-page ${p === currentPage ? 'is-active' : ''}`}
            aria-current={p === currentPage ? 'page' : undefined}
          >
            {p}
          </a>
        ))}

      {showEllipsisEnd && (
        <>
          <span class="pagination-ellipsis">...</span>
          <a href={getPageUrl(totalPages)} class="pagination-page">{totalPages}</a>
        </>
      )}
    </div>

    {currentPage < totalPages && (
      <a href={getPageUrl(currentPage + 1)} class="pagination-next" aria-label="Next page">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    )}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: calc(var(--spacing) * 3);
    padding-top: calc(var(--spacing) * 2);
    border-top: 1px solid var(--color-border);
  }
  .pagination-pages {
    display: flex;
    gap: 0.25rem;
  }
  .pagination-page,
  .pagination-prev,
  .pagination-next {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: background 0.15s;
  }
  .pagination-page:hover,
  .pagination-prev:hover,
  .pagination-next:hover {
    background: var(--color-muted);
  }
  .pagination-page.is-active {
    background: var(--color-primary);
    color: white;
  }
  .pagination-ellipsis {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    color: var(--color-text-muted);
  }
</style>
