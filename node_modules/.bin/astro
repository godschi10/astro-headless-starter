#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/astro-headless-starter/node_modules/.pnpm/astro@6.4.6_jiti@2.7.0_lightningcss@1.32.0_rollup@4.61.1/node_modules/astro/node_modules:/home/ubuntu/astro-headless-starter/node_modules/.pnpm/astro@6.4.6_jiti@2.7.0_lightningcss@1.32.0_rollup@4.61.1/node_modules:/home/ubuntu/astro-headless-starter/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/astro-headless-starter/node_modules/.pnpm/astro@6.4.6_jiti@2.7.0_lightningcss@1.32.0_rollup@4.61.1/node_modules/astro/node_modules:/home/ubuntu/astro-headless-starter/node_modules/.pnpm/astro@6.4.6_jiti@2.7.0_lightningcss@1.32.0_rollup@4.61.1/node_modules:/home/ubuntu/astro-headless-starter/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../astro/bin/astro.mjs" "$@"
else
  exec node  "$basedir/../astro/bin/astro.mjs" "$@"
fi
